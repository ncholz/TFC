<UserControl x:Class="Prueba_pizarra.PizarraTactical"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Syne"
             Height="600" Width="800">

    <Grid>
        <Image Source="cancha.jpg" Stretch="UniformToFill" Opacity="0.9"/>

        <Canvas x:Name="CapaJugadores">
            <Ellipse Fill="#E67E22" Width="24" Height="24" Canvas.Left="388" Canvas.Top="288"
                     Stroke="Black" StrokeThickness="2" Panel.ZIndex="10"
                     MouseLeftButtonDown="Ficha_MouseDown" MouseMove="Ficha_MouseMove" MouseLeftButtonUp="Ficha_MouseUp"/>

            <Ellipse Fill="#E74C3C" Width="35" Height="35" Canvas.Left="100" Canvas.Top="100" Stroke="White" StrokeThickness="3" MouseLeftButtonDown="Ficha_MouseDown" MouseMove="Ficha_MouseMove" MouseLeftButtonUp="Ficha_MouseUp">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Fill="#E74C3C" Width="35" Height="35" Canvas.Left="100" Canvas.Top="180" Stroke="White" StrokeThickness="3" MouseLeftButtonDown="Ficha_MouseDown" MouseMove="Ficha_MouseMove" MouseLeftButtonUp="Ficha_MouseUp">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Fill="#E74C3C" Width="35" Height="35" Canvas.Left="100" Canvas.Top="260" Stroke="White" StrokeThickness="3" MouseLeftButtonDown="Ficha_MouseDown" MouseMove="Ficha_MouseMove" MouseLeftButtonUp="Ficha_MouseUp">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Fill="#E74C3C" Width="35" Height="35" Canvas.Left="100" Canvas.Top="340" Stroke="White" StrokeThickness="3" MouseLeftButtonDown="Ficha_MouseDown" MouseMove="Ficha_MouseMove" MouseLeftButtonUp="Ficha_MouseUp">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Fill="#E74C3C" Width="35" Height="35" Canvas.Left="100" Canvas.Top="420" Stroke="White" StrokeThickness="3" MouseLeftButtonDown="Ficha_MouseDown" MouseMove="Ficha_MouseMove" MouseLeftButtonUp="Ficha_MouseUp">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>

            <Ellipse Fill="#3498DB" Width="35" Height="35" Canvas.Left="665" Canvas.Top="100" Stroke="White" StrokeThickness="3" MouseLeftButtonDown="Ficha_MouseDown" MouseMove="Ficha_MouseMove" MouseLeftButtonUp="Ficha_MouseUp">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Fill="#3498DB" Width="35" Height="35" Canvas.Left="665" Canvas.Top="180" Stroke="White" StrokeThickness="3" MouseLeftButtonDown="Ficha_MouseDown" MouseMove="Ficha_MouseMove" MouseLeftButtonUp="Ficha_MouseUp">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Fill="#3498DB" Width="35" Height="35" Canvas.Left="665" Canvas.Top="260" Stroke="White" StrokeThickness="3" MouseLeftButtonDown="Ficha_MouseDown" MouseMove="Ficha_MouseMove" MouseLeftButtonUp="Ficha_MouseUp">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Fill="#3498DB" Width="35" Height="35" Canvas.Left="665" Canvas.Top="340" Stroke="White" StrokeThickness="3" MouseLeftButtonDown="Ficha_MouseDown" MouseMove="Ficha_MouseMove" MouseLeftButtonUp="Ficha_MouseUp">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Fill="#3498DB" Width="35" Height="35" Canvas.Left="665" Canvas.Top="420" Stroke="White" StrokeThickness="3" MouseLeftButtonDown="Ficha_MouseDown" MouseMove="Ficha_MouseMove" MouseLeftButtonUp="Ficha_MouseUp">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="5" ShadowDepth="3" Opacity="0.5"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <InkCanvas x:Name="PizarraInk" Background="Transparent"/>

        <Border Background="#EEFFFFFF" VerticalAlignment="Bottom" HorizontalAlignment="Center" CornerRadius="15" Padding="10,5" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <Button Content="🖐 Mover Fichas" Click="BtnModoMover_Click" Width="120" Height="35" Margin="5" Background="#2C3E50" Foreground="White"/>
                <Button Content="✏️ Dibujar Jugada" Click="BtnModoDibujar_Click" Width="130" Height="35" Margin="5" Background="#27AE60" Foreground="White"/>
                <Button Content="🗑 Borrar Líneas" Click="BtnBorrar_Click" Width="120" Height="35" Margin="5" Background="#C0392B" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>